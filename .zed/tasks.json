// .zed/tasks.json
[
  {
    "label": "Cargo: Run",
    "command": "cargo run",
    "use_new_terminal": false,
    "allow_concurrent_runs": false
  },
  {
    "label": "Cargo: Test",
    "command": "cargo test",
    "use_new_terminal": true
  },
  {
    "label": "Cargo: Clippy Fix",
    "command": "cargo clippy --fix --allow-dirty --allow-staged",
    "use_new_terminal": false
  },
  {
    "label": "DB: Ejecutar SQL actual en MariaDB",
    "command": "mariadb -u fedechess -pMi_Passwd fedechess < $ZED_FILE",
    "use_new_terminal": true,
    "hide_terminal": false
  },
  {
    "label": "DB: Migraciones / Seed",
    "command": "mariadb -u fedechess -pFedTin2026 fedechess < migrations/init.sql",
    "use_new_terminal": true
  }
]
