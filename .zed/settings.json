{
  "vim_mode": true,
  "format_on_save": "on",
  "soft_wrap": "editor_width",
  "languages": {
    "Rust": {
      "format_on_save": "on",
      "formatter": "auto",
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "Markdown": {
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 80,
      "format_on_save": "on",
    },
    "SQL": {
      "format_on_save": "on",
      "tab_size": 2,
    },
  },
  "lsp": {
    "rust-analyzer": {
      "settings": {
        "checkOnSave": true,
        "check": {
          "command": "clippy",
        },
      },
    },
  },
}
